// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "dependsOn": ["watch:tsc-ext", "watch:build"],
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "watch:build",
      "group": "build",
      "problemMatcher": {
        "owner": "rolldown",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^(?:\\[[^\\]]+\\]\\s+)?Error:\\s+(.+)$",
            "message": 1
          },
          {
            "regexp": "\\[\\s+([^:]+):(\\d+):(\\d+)\\s+\\]",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "rebuilding...$",
          "endsPattern": "^✔ Rebuilt "
        }
      },
      "isBackground": true,
      "label": "watch:build",
      "presentation": {
        "group": "watch",
        "reveal": "silent"
      }
    },
    {
      "type": "npm",
      "script": "watch:tsc-ext",
      "group": "build",
      "problemMatcher": {
        "owner": "tsgo",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^(.+):(\\d+):(\\d+) - error(.+)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^build starting at",
          "endsPattern": "^build finished in"
        }
      },
      "isBackground": true,
      "label": "watch:tsc-ext",
      "presentation": {
        "group": "watch",
        "reveal": "silent"
      }
    },
    {
      "type": "npm",
      "script": "watch-tests",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "label": "watch-tests",
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      },
      "group": "build"
    },
    {
      "label": "tasks: watch-tests",
      "dependsOn": ["npm: watch", "watch-tests"],
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "compile",
      "label": "npm: compile",
      "group": "build"
    },
    {
      "type": "npm",
      "script": "package",
      "label": "npm: package",
      "group": "build"
    }
  ]
}
