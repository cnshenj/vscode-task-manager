{
  "name": "vscode-task-manager",
  "displayName": "Task Manager",
  "version": "1.3.0",
  "description": "Manages tasks in Visual Studio Code.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "manage",
    "task"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "url": "https://github.com/cnshenj/vscode-task-manager"
  },
  "publisher": "cnshenj",
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && rolldown -c",
    "watch": "npm-run-all -p watch:*",
    "watch:build": "rolldown -c -w",
    "watch:tsc": "tsgo --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && cross-env NODE_ENV=production rolldown -c",
    "compile-tests": "rimraf out && tsgo -p . --outDir out",
    "watch-tests": "tsgo -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsgo --noEmit",
    "lint": "oxlint --config .oxlintrc.json --type-aware src",
    "test": "vscode-test",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "1.103.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "cross-env": "^10.1.0",
    "jsonc-parser": "^3.3.1",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.19.0",
    "rimraf": "^6.1.3",
    "rolldown": "1.0.0-rc.17"
  },
  "contributes": {
    "commands": [
      {
        "command": "task-manager-tasks.refresh",
        "title": "Refresh Tasks",
        "category": "Task Manager",
        "icon": "$(sync)"
      },
      {
        "command": "task-manager-tasks.configure",
        "title": "Configure Task",
        "category": "Task Manager",
        "icon": "$(gear)"
      },
      {
        "command": "task-manager-tasks.terminateAll",
        "title": "Terminate All Running Tasks",
        "category": "Task Manager",
        "icon": "$(debug-stop)"
      },
      {
        "command": "task-manager-tasks.run",
        "title": "Run Task",
        "category": "Task Manager",
        "icon": "$(debug-start)"
      },
      {
        "command": "task-manager-tasks.viewSource",
        "title": "View Source",
        "category": "Task Manager",
        "icon": "$(go-to-file)"
      },
      {
        "command": "task-manager-tasks.terminate",
        "title": "Terminate Task",
        "category": "Task Manager",
        "icon": "$(debug-stop)"
      },
      {
        "command": "task-manager-tasks.restart",
        "title": "Restart Task",
        "category": "Task Manager",
        "icon": "$(debug-restart)"
      },
      {
        "command": "task-manager-tasks.favorite",
        "title": "Favorite Task",
        "category": "Task Manager",
        "icon": "$(star-empty)"
      },
      {
        "command": "task-manager-tasks.unfavorite",
        "title": "Unfavorite Task",
        "category": "Task Manager",
        "icon": "$(star-full)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "task-manager",
          "title": "Task Manager",
          "icon": "resources/task.svg"
        }
      ]
    },
    "views": {
      "task-manager": [
        {
          "id": "task-manager-tasks",
          "name": "Tasks",
          "icon": "$(tasklist)"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "task-manager-tasks.refresh",
          "when": "false"
        },
        {
          "command": "task-manager-tasks.configure",
          "when": "false"
        },
        {
          "command": "task-manager-tasks.terminateAll",
          "when": "false"
        },
        {
          "command": "task-manager-tasks.run",
          "when": "false"
        },
        {
          "command": "task-manager-tasks.viewSource",
          "when": "false"
        },
        {
          "command": "task-manager-tasks.terminate",
          "when": "false"
        },
        {
          "command": "task-manager-tasks.restart",
          "when": "false"
        },
        {
          "command": "task-manager-tasks.favorite",
          "when": "false"
        },
        {
          "command": "task-manager-tasks.unfavorite",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "task-manager-tasks.refresh",
          "when": "view == task-manager-tasks",
          "group": "navigation@1"
        },
        {
          "command": "task-manager-tasks.configure",
          "when": "view == task-manager-tasks",
          "group": "navigation@2"
        },
        {
          "command": "task-manager-tasks.terminateAll",
          "when": "view == task-manager-tasks"
        }
      ],
      "view/item/context": [
        {
          "command": "task-manager-tasks.run",
          "when": "view == task-manager-tasks && (viewItem == task || viewItem == favoriteTask)",
          "group": "inline@1"
        },
        {
          "command": "task-manager-tasks.terminate",
          "when": "view == task-manager-tasks && (viewItem == runningTask || viewItem == runningFavoriteTask)",
          "group": "inline@1"
        },
        {
          "command": "task-manager-tasks.restart",
          "when": "view == task-manager-tasks && (viewItem == runningTask || viewItem == runningFavoriteTask)",
          "group": "inline@2"
        },
        {
          "command": "task-manager-tasks.viewSource",
          "when": "view == task-manager-tasks && (viewItem == task || viewItem == favoriteTask || viewItem == runningTask || viewItem == runningFavoriteTask)",
          "group": "inline@3"
        },
        {
          "command": "task-manager-tasks.favorite",
          "when": "view == task-manager-tasks && (viewItem == task || viewItem == runningTask)",
          "group": "inline@5"
        },
        {
          "command": "task-manager-tasks.unfavorite",
          "when": "view == task-manager-tasks && (viewItem == favoriteTask || viewItem == runningFavoriteTask)",
          "group": "inline@5"
        }
      ]
    },
    "configuration": [
      {
        "title": "Task Manager",
        "properties": {
          "taskManager.exclude": {
            "type": "string",
            "default": null,
            "description": "Regular expression pattern for excluding tasks."
          },
          "taskManager.collapseLargeTaskTree": {
            "type": "boolean",
            "default": true,
            "description": "Collapse the task tree to top-level groups when there are more than three groups and more than 30 tasks."
          },
          "taskManager.taskSortOrder": {
            "type": "string",
            "default": "label",
            "enum": [
              "label",
              "group",
              "provider"
            ],
            "enumDescriptions": [
              "Sort tasks alphabetically by label.",
              "Sort tasks by task group, then alphabetically by label.",
              "Keep tasks in the order returned by VS Code task providers."
            ],
            "description": "Controls how task items are sorted."
          },
          "taskManager.favorites": {
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            },
            "description": "Favorite task identifiers saved in workspace settings."
          }
        }
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "images/logo.png",
  "engines": {
    "vscode": "^1.103.0"
  },
  "packageManager": "pnpm@10.33.0"
}
